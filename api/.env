API_APP_NAME=recruitment-main-api
API_DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/recruitment
API_JWT_SECRET_KEY=super-secret-key
API_JWT_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=60
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
API_RABBITMQ_QUEUE=hh.responses
API_RABBITMQ_ENABLED=true
API_RABBITMQ_RECONNECT_DELAY_SECONDS=5

# RabbitMQ Container Configuration
RABBITMQ_IMAGE=rabbitmq:3-management-alpine
RABBITMQ_CONTAINER_NAME=recruitment-rabbitmq
RABBITMQ_RESTART_POLICY=unless-stopped
RABBITMQ_DATA_PATH=/data/rabbitmq
RABBITMQ_HEALTHCHECK_INTERVAL=30s
RABBITMQ_HEALTHCHECK_TIMEOUT=10s
RABBITMQ_HEALTHCHECK_RETRIES=5
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# PostgreSQL Configuration
POSTGRES_IMAGE=postgres:15-alpine
POSTGRES_CONTAINER_NAME=my-postgres-container
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HEALTHCHECK_INTERVAL=30s
POSTGRES_HEALTHCHECK_TIMEOUT=10s
POSTGRES_HEALTHCHECK_RETRIES=5
POSTGRES_DATA_PATH=/data/postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=./postgres-init:/docker-entrypoint-initdb.d
POSTGRES_RESTART_POLICY=unless-stopped
POSTGRES_VOLUME_NAME=postgres_data

# Additional variables
API_CONTAINER_NAME=recruitment-api-container
API_RESTART_POLICY=unless-stopped
API_BUILD_CONTEXT=.
API_DOCKERFILE=Dockerfile
RABBITMQ_VOLUME_NAME=rabbitmq_data